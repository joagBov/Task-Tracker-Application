    FIRST VERSION : 2025
    DESCRIPTION   : Razor view for the main dashboard displaying task statistics,
					search functionality, and a detailed task list with action buttons.
-->
@model List<TaskTracker.Models.TaskItem>

@{
    ViewData["Title"] = "Task Dashboard";
}

<!-- Main Dashboard Container -->
<div class="container-fluid">
    <!-- Page Header with Create Button -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="page-header">Task Dashboard</h1>
        <!-- Create New Task Button -->
        <a href="@Url.Action("Create")" class="btn btn-primary">
             Create New Task
        </a>
    </div>

    <!-- Message Box Container for User Feedback -->
    <div id="messageBox" style="display: none;">
        <div class="message-box-content">
            <div class="d-flex align-items-center">
                <div class="alert-icon"></div>
                <div class="alert-content flex-grow-1"></div>
                <!-- Close Button for Message Box -->
                <button type="button" class="btn-close" onclick="hideMessageBox()"></button>
            </div>
        </div>
    </div>

    <!-- Search Section Card -->
    <div class="card mb-4">
        <div class="card-body">
            <h5 class="card-title"> Search Tasks</h5>
            <!-- Search Form with Client-Side Validation -->
            <form asp-action="Search" method="get" class="row g-3" onsubmit="return validateSearch()">
                <div class="col-md-6">
                    <!-- Search Term Input -->
                    <input type="text" name="searchTerm" id="searchTerm" class="form-control"
                           placeholder="Enter search term..." value="@Context.Request.Query["searchTerm"]">
                </div>
                <div class="col-md-4">
                    <!-- Search Type Dropdown -->
                    @{
                        var currentSearchType = Context.Request.Query["searchType"].ToString();
                        if (string.IsNullOrEmpty(currentSearchType))
                        {
                            currentSearchType = "id";
                        }
                    }
                    <select name="searchType" id="searchType" class="form-select">
                        <option value="id" selected="@(currentSearchType == "id")">Search by ID</option>
                        <option value="assignee" selected="@(currentSearchType == "assignee")">Search by Assignee</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <!-- Search Submit Button -->
                    <button type="submit" class="btn btn-primary w-100">Search</button>
                </div>
            </form>

            <!-- Clear Search Link (Visible only when search is active) -->
            @if (!string.IsNullOrEmpty(Context.Request.Query["searchTerm"]))
            {
                <div class="mt-2">
                    <a href="@Url.Action("Index")" class="btn btn-outline-secondary btn-sm">Clear Search</a>
                </div>
            }
        </div>
    </div>

    <!-- Task Summary Statistics Cards -->
    <div class="row mb-4">
        <!-- Total Tasks Card -->
        <div class="col-md-3">
            <div class="card text-white bg-primary">
                <div class="card-body">
                    <h5 class="card-title"> Total Tasks</h5>
                    <h2 class="card-text">@Model.Count</h2>
                </div>
            </div>
        </div>

        <!-- Assigned Tasks Card -->
        <div class="col-md-3">
            <div class="card text-white bg-success">
                <div class="card-body">
                    <h5 class="card-title"> Assigned Tasks</h5>
                    <h2 class="card-text">@Model.Count(t => !string.IsNullOrEmpty(t.Assignee))</h2>
                </div>
            </div>
        </div>

        <!-- High Priority Tasks Card -->
        <div class="col-md-3">
            <div class="card text-white bg-warning">
                <div class="card-body">
                    <h5 class="card-title"> High Priority</h5>
                    <h2 class="card-text">@Model.Count(t => t.Priority >= TaskTracker.Models.Priority.High)</h2>
                </div>
            </div>
        </div>

        <!-- Completed Tasks Card -->
        <div class="col-md-3">
            <div class="card text-white bg-info">
                <div class="card-body">
                    <h5 class="card-title"> Completed</h5>
                    <h2 class="card-text">@Model.Count(t => t.IsCompleted)</h2>
                </div>
            </div>
        </div>
    </div>

    <!-- Main Tasks Table Section -->
    <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h5 class="card-title mb-0">Task List</h5>
            <!-- Search Active Badge (Visible when search is performed) -->
            @if (!string.IsNullOrEmpty(Context.Request.Query["searchTerm"]))
            {
                <span class="badge bg-primary">
                    Search: "@Context.Request.Query["searchTerm"]"
                    (@(Context.Request.Query["searchType"] == "id" ? "by ID" : "by Assignee"))
                </span>
            }
        </div>
        <div class="card-body">
            @if (Model.Any())
            {
                <!-- Responsive Table Container -->
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Title</th>
                                <th>Assignee</th>
                                <th>Priority</th>
                                <th>Status</th>
                                <th>Created</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            <!-- Loop through each task and display in table rows -->
                            @foreach (var task in Model)
                            {
                                <tr>
                                    <td><strong>#@task.Id</strong></td>
                                    <td>@task.Title</td>
                                    <td>
                                        <!-- Conditional Assignee Display -->
                                        @if (string.IsNullOrEmpty(task.Assignee))
                                        {
                                            <span class="badge bg-secondary">Unassigned</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-success">@task.Assignee</span>
                                        }
                                    </td>
                                    <td>
                                        <!-- Priority Badge with Dynamic Coloring -->
                                        <span class="badge @GetPriorityBadgeClass(task.Priority)">
                                            @task.Priority
                                        </span>
                                    </td>
                                    <td>
                                        <!-- Status Badge (Completed/Pending) -->
                                        @if (task.IsCompleted)
                                        {
                                            <span class="badge bg-success">Completed</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-warning">Pending</span>
                                        }
                                    </td>
                                    <td>@task.CreatedDate.ToString("MMM dd, yyyy")</td>
                                    <td>
                                        <!-- Action Buttons for Each Task -->
                                        <div class="action-buttons">
                                            <a href="@Url.Action("Details", new { id = task.Id })" class="btn btn-sm btn-info"> View</a>
                                            <a href="@Url.Action("Edit", new { id = task.Id })" class="btn btn-sm btn-warning"> Edit</a>
                                            <!-- Delete Form with Confirmation -->
                                            <form asp-action="Delete" method="post" class="d-inline">
                                                <input type="hidden" name="id" value="@task.Id" />
                                                <button type="submit" class="btn btn-sm btn-danger"
                                                        onclick="return confirm('Are you sure you want to delete this task?')">
                                                     Delete
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <!-- Empty State Messages -->
                <div class="text-center py-4">
                    @if (!string.IsNullOrEmpty(Context.Request.Query["searchTerm"]))
                    {
                        <!-- No Search Results Message -->
                        <h4> No tasks match your search</h4>
                        <p class="text-muted">No tasks found for "@Context.Request.Query["searchTerm"]"</p>
                        <a href="@Url.Action("Index")" class="btn btn-primary">Show All Tasks</a>
                    }
                    else
                    {
                        <!-- No Tasks Created Message -->
                        <h4> No tasks found</h4>
                        <p class="text-muted">Get started by creating your first task!</p>
                        <a href="@Url.Action("Create")" class="btn btn-primary">Create Task</a>
                    }
                </div>
            }
        </div>
    </div>
</div>

@functions {
    /// <summary>
    /// Returns appropriate Bootstrap badge class based on task priority level
    /// </summary>
    /// <param name="priority">Priority level of the task</param>
    /// <returns>CSS class name for badge styling</returns>
    string GetPriorityBadgeClass(TaskTracker.Models.Priority priority)
    {
        return priority switch
        {
            TaskTracker.Models.Priority.None => "bg-secondary",      // Gray - No priority set
            TaskTracker.Models.Priority.Low => "bg-success",         // Green - Low priority
            TaskTracker.Models.Priority.Medium => "bg-info",         // Blue - Medium priority
            TaskTracker.Models.Priority.High => "bg-warning",        // Yellow - High priority
            TaskTracker.Models.Priority.Critical => "bg-danger",     // Red - Critical priority
            _ => "bg-secondary"                                      // Default fallback
        };
    }
}

<!-- Custom CSS Styles for Message Box and Animations -->
<style>
    /* Message Box Positioning and Styling */
    #messageBox {
        position: fixed;
        top: 20px;
        left: 50%;
        transform: translateX(-50%);
        z-index: 1050;
        min-width: 450px;
        max-width: 600px;
        width: auto;
    }

    /* Message Box Content Styling */
    .message-box-content {
        padding: 20px 25px;
        border-radius: 10px;
        border-left: 6px solid;
        box-shadow: 0 4px 20px rgba(0,0,0,0.25);
        font-size: 16px;
        font-weight: 500;
        margin-bottom: 10px;
    }

    /* Alert Icon Styling */
    .alert-icon {
        width: 32px;
        height: 32px;
        margin-right: 15px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: bold;
        font-size: 18px;
        flex-shrink: 0;
    }

    /* Alert Content Area */
    .alert-content {
        font-size: 16px;
        line-height: 1.5;
        padding-right: 10px;
    }

    /* Close Button Styling */
    .btn-close {
        flex-shrink: 0;
        opacity: 0.8;
        width: 20px;
        height: 20px;
    }

        .btn-close:hover {
            opacity: 1;
        }

    /* Success Message Styling */
    .message-success {
        background-color: lightgreen;
        border-left-color: green;
        color: darkgreen;
        border: 1px solid limegreen;
    }

        .message-success .alert-icon {
            background-color: green;
            color: white;
        }

    /* Error Message Styling */
    .message-error {
        background-color: lightpink;
        border-left-color: red;
        color: darkred;
        border: 1px solid pink;
    }

        .message-error .alert-icon {
            background-color: red;
            color: white;
        }

    /* Warning Message Styling */
    .message-warning {
        background-color: lightyellow;
        border-left-color: yellow;
        color: darkgoldenrod;
        border: 1px solid palegoldenrod;
    }

        .message-warning .alert-icon {
            background-color: yellow;
            color: darkgoldenrod;
        }

    /* Info Message Styling */
    .message-info {
        background-color: white;
        border-left-color: cyan;
        color: darkturquoise;
        border: 1px solid gray;
    }

        .message-info .alert-icon {
            background-color: aqua;
            color: white;
        }

    /* Slide In Animation for Message Box */
    @@keyframes slideInDown {
        from {
            transform: translateX(-50%) translateY(-100%);
            opacity: 0;
        }

        to {
            transform: translateX(-50%) translateY(0);
            opacity: 1;
        }
    }

    /* Slide Out Animation for Message Box */
    @@keyframes slideOutUp {
        from {
            transform: translateX(-50%) translateY(0);
            opacity: 1;
        }

        to {
            transform: translateX(-50%) translateY(-100%);
            opacity: 0;
        }
    }

    /* Animation Classes for Show/Hide States */
    .message-show {
        animation: slideInDown 0.3s ease-out;
    }

    .message-hide {
        animation: slideOutUp 0.3s ease-in;
    }

    /* Status Code Styling in Messages */
    .status-code {
        font-weight: bold;
        font-size: 18px;
        margin-right: 8px;
        padding: 2px 6px;
        border-radius: 4px;
        background-color: rgba(255,255,255,0.3);
    }
</style>

<!-- JavaScript for Interactive Functionality -->
<script>
    function showMessageBox(message, type) {
        const messageBox = document.getElementById('messageBox');
        const messageContent = messageBox.querySelector('.message-box-content');
        const alertIcon = messageBox.querySelector('.alert-icon');
        const alertContent = messageBox.querySelector('.alert-content');

        // Remove existing classes and apply new type
        messageContent.className = 'message-box-content';
        messageContent.classList.add(`message-${type}`);

        // Apply show animation
        messageBox.classList.remove('message-hide');
        messageBox.classList.add('message-show');

        // Set appropriate icon based on message type
        switch(type) {
            case 'success':
                alertIcon.innerHTML = '✓';
                break;
            case 'error':
                alertIcon.innerHTML = '✕';
                break;
            case 'warning':
                alertIcon.innerHTML = '⚠';
                break;
            case 'info':
                alertIcon.innerHTML = 'ℹ';
                break;
        }

        // Format message with status code if present
        let formattedMessage = message;
        const statusMatch = message.match(/^(\d{3}) - (.*)/);
        if (statusMatch) {
            const statusCode = statusMatch[1];
            const messageText = statusMatch[2];
            formattedMessage = `<span class="status-code">${statusCode}</span>${messageText}`;
        }

        alertContent.innerHTML = formattedMessage;
        messageBox.style.display = 'block';

        // Auto-hide message after 5 seconds
        setTimeout(hideMessageBox, 5000);
    }

    /**
     * Hides the message box with slide-out animation
     */
    function hideMessageBox() {
        const messageBox = document.getElementById('messageBox');
        messageBox.classList.remove('message-show');
        messageBox.classList.add('message-hide');

        // Wait for animation completion before hiding completely
        setTimeout(() => {
            messageBox.style.display = 'none';
            messageBox.classList.remove('message-hide');
        }, 300);
    }

    function validateSearch() {
        const searchTerm = document.getElementById('searchTerm').value.trim();
        const searchType = document.getElementById('searchType').value;

        // Check if search term is provided
        if (!searchTerm) {
            showMessageBox('400 - Please enter a search term', 'warning');
            return false;
        }

        // Validate numeric input for ID search
        if (searchType === 'id' && isNaN(searchTerm)) {
            showMessageBox('400 - Please enter a valid numeric ID for ID search', 'warning');
            return false;
        }

        return true;
    }

    // Initialize functionality when DOM is fully loaded
    document.addEventListener('DOMContentLoaded', function() {
        // Display server-side messages if present
        @if (ViewBag.SearchMessage != null)
        {
                var message = ViewBag.SearchMessage.ToString();
                if (message.StartsWith("200") || message.StartsWith("201") || message.StartsWith("204"))
                {
                        <text>showMessageBox('@message', 'success');</text>
                }
                else if (message.StartsWith("400"))
                {
                        <text>showMessageBox('@message', 'warning');</text>
                }
                else if (message.StartsWith("404"))
                {
                        <text>showMessageBox('@message', 'error');</text>
                }
                else
                {
                        <text>showMessageBox('@message', 'info');</text>
                }
        }

        // Show appropriate message for empty search results
        const urlParams = new URLSearchParams(window.location.search);
        const searchTerm = urlParams.get('searchTerm');
        const searchType = urlParams.get('searchType');

        if (searchTerm && @Model.Count == 0) {
            if (searchType === 'id') {
                showMessageBox('404 - No task found with ID: ' + searchTerm, 'error');
            } else {
                showMessageBox('404 - No tasks found for assignee: ' + searchTerm, 'info');
            }
        }
    });

    // Add close button functionality
    document.addEventListener('DOMContentLoaded', function() {
        const closeButton = document.querySelector('#messageBox .btn-close');
        if (closeButton) {
            closeButton.addEventListener('click', hideMessageBox);
        }
    });

    // Add click-outside-to-close functionality
    document.addEventListener('DOMContentLoaded', function() {
        const messageBox = document.getElementById('messageBox');
        if (messageBox) {
            messageBox.addEventListener('click', function(e) {
                if (e.target === this) {
                    hideMessageBox();
                }
            });
        }
    });
</script>