<!--
    FILE          : Details.cshtml
    PROJECT       : Task Tracker Application
    PROGRAMMER(S) : Mehakpreet Singh, Elijah Atta-Konadu, Navjot Singh Bhullar, Chase Mccash
    FIRST VERSION : 2025
    DESCRIPTION   : Razor view to display detailed information about a specific task,
                    including options to edit, delete, assign, and set priority.
-->
@model TaskTracker.Models.TaskItem

@{
    ViewData["Title"] = "Task Details";
}

<div class="row">
    <!-- Main Task Information Section -->
    <div class="col-md-8">
        <!-- Task Information Card - Displays all task details -->
        <div class="card mb-4">
            <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                <!-- Task header with ID and status badge -->
                <h2 class="card-title mb-0">Task #@Model.Id</h2>
                <div>
                    <!-- Dynamic status badge showing completion state -->
                    <span class="badge @(Model.IsCompleted ? "bg-success" : "bg-warning")">
                        @(Model.IsCompleted ? "Completed" : "Pending")
                    </span>
                </div>
            </div>
            <div class="card-body">
                <!-- Task Title -->
                <div class="row mb-3">
                    <div class="col-sm-3 fw-bold text-primary">Title:</div>
                    <div class="col-sm-9">@Model.Title</div>
                </div>

                <!-- Task Description with fallback for empty descriptions -->
                <div class="row mb-3">
                    <div class="col-sm-3 fw-bold text-primary">Description:</div>
                    <div class="col-sm-9">@(string.IsNullOrEmpty(Model.Description) ? "No description" : Model.Description)</div>
                </div>

                <!-- Assignee Information with conditional display -->
                <div class="row mb-3">
                    <div class="col-sm-3 fw-bold text-primary">Assignee:</div>
                    <div class="col-sm-9">
                        @if (string.IsNullOrEmpty(Model.Assignee))
                        {
                            <!-- Show unassigned badge if no assignee -->
                            <span class="badge bg-secondary">Unassigned</span>
                        }
                        else
                        {
                            <!-- Show assignee name with success badge -->
                            <span class="badge bg-success">@Model.Assignee</span>
                        }
                    </div>
                </div>

                <!-- Priority Information with dynamic badge coloring -->
                <div class="row mb-3">
                    <div class="col-sm-3 fw-bold text-primary">Priority:</div>
                    <div class="col-sm-9">
                        <span class="badge @GetPriorityBadgeClass(Model.Priority)">
                            @Model.Priority
                        </span>
                    </div>
                </div>

                <!-- Creation Date -->
                <div class="row mb-3">
                    <div class="col-sm-3 fw-bold text-primary">Created:</div>
                    <div class="col-sm-9">@Model.CreatedDate.ToString("MMM dd, yyyy 'at' hh:mm tt")</div>
                </div>

                <!-- Last Updated Date with null check -->
                <div class="row">
                    <div class="col-sm-3 fw-bold text-primary">Last Updated:</div>
                    <div class="col-sm-9">@(Model.UpdatedDate?.ToString("MMM dd, yyyy 'at' hh:mm tt") ?? "Never")</div>
                </div>
            </div>
        </div>
    </div>

    <!-- Sidebar Action Panel -->
    <div class="col-md-4">
        <!-- Quick Actions Card - Primary task operations -->
        <div class="card mb-3">
            <div class="card-header bg-info text-white">
                <h5 class="card-title mb-0"> Quick Actions</h5>
            </div>
            <div class="card-body">
                <div class="d-grid gap-2">
                    <!-- Edit Task Button -->
                    <a href="@Url.Action("Edit", new { id = Model.Id })" class="btn btn-warning">
                         Edit Task
                    </a>

                    <!-- Delete Task Form with confirmation -->
                    <form asp-action="Delete" method="post" class="d-grid">
                        <input type="hidden" name="id" value="@Model.Id" />
                        <button type="submit" class="btn btn-danger"
                                onclick="return confirm('Are you sure you want to delete this task?')">
                            Delete Task
                        </button>
                    </form>
                </div>
            </div>
        </div>

        <!-- Task Management Card - Additional task operations -->
        <div class="card">
            <div class="card-header bg-success text-white">
                <h5 class="card-title mb-0"> Task Management</h5>
            </div>
            <div class="card-body">
                <!-- Assign Task Form -->
                <form asp-action="Assign" method="post" class="mb-3">
                    <input type="hidden" name="id" value="@Model.Id" />
                    <label class="form-label small">Assign to User</label>
                    <div class="input-group">
                        <input type="text" name="assignee" class="form-control" placeholder="Username..." required>
                        <button type="submit" class="btn btn-success">Assign</button>
                    </div>
                </form>

                <!-- Set Priority Form -->
                <form asp-action="SetPriority" method="post" class="mb-3">
                    <input type="hidden" name="id" value="@Model.Id" />
                    <label class="form-label small">Set Priority</label>
                    <div class="input-group">
                        <!-- Priority dropdown with all available options -->
                        <select name="priority" class="form-select">
                            <option value="None">None</option>
                            <option value="Low">Low</option>
                            <option value="Medium">Medium</option>
                            <option value="High">High</option>
                            <option value="Critical">Critical</option>
                        </select>
                        <button type="submit" class="btn btn-warning">Set</button>
                    </div>
                </form>

                <!-- Remove Actions Section -->
                <div class="d-grid gap-2">
                    <!-- Remove Assignee Form -->
                    <form asp-action="RemoveAssignee" method="post" class="d-grid">
                        <input type="hidden" name="id" value="@Model.Id" />
                        <button type="submit" class="btn btn-outline-secondary btn-sm">
                            Remove Assignee
                        </button>
                    </form>

                    <!-- Remove Priority Form -->
                    <form asp-action="RemovePriority" method="post" class="d-grid">
                        <input type="hidden" name="id" value="@Model.Id" />
                        <button type="submit" class="btn btn-outline-secondary btn-sm">
                            Remove Priority
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Navigation Back to Task List -->
<div class="mt-4">
    <a href="@Url.Action("Index")" class="btn btn-secondary">← Back to Task List</a>
</div>

@functions {
    /// <summary>
    /// Returns the appropriate Bootstrap badge class based on task priority
    /// </summary>
    /// <param name="priority">The priority level of the task</param>
    /// <returns>CSS class name for the badge styling</returns>
    string GetPriorityBadgeClass(TaskTracker.Models.Priority priority)
    {
        return priority switch
        {
            TaskTracker.Models.Priority.None => "bg-secondary",      // Gray for no priority
            TaskTracker.Models.Priority.Low => "bg-success",         // Green for low priority
            TaskTracker.Models.Priority.Medium => "bg-info",         // Blue for medium priority
            TaskTracker.Models.Priority.High => "bg-warning",        // Yellow for high priority
            TaskTracker.Models.Priority.Critical => "bg-danger",     // Red for critical priority
            _ => "bg-secondary"                                      // Default fallback
        };
    }
}